-- Brainrot Hub Loader
-- Změň tyto dvě řádky podle sebe ↓↓↓
local XOR_KEY = "aVysHSYBTqIuFaQW"   -- ← můžeš změnit na vlastní delší klíč
local PAYLOAD_URL = "https://raw.githubusercontent.com/janhub1/scriptsurvivelava/main/payload.xor"

if getgenv and getgenv().BrainrotHubLoaded then return end
getgenv().BrainrotHubLoaded = true

local function xorDecrypt(str, key)
    local result = {}
    for i = 1, #str do
        local k = key:byte((i - 1) % #key + 1)
        local c = str:byte(i)
        result[i] = string.char(bit32.band(bit32.bxor(c, k), 0xFF))
    end
    return table.concat(result)
end

local HttpService = game:GetService("HttpService")
local success, response = pcall(function()
    return HttpService:GetAsync(PAYLOAD_URL)
end)

if not success then
    warn("[Loader] Nepodařilo se stáhnout payload: " .. tostring(response))
    return
end

local decrypted = xorDecrypt(response, XOR_KEY)

local func, err = loadstring(decrypted)
if not func then
    warn("[Loader] Chyba v kódu: " .. tostring(err))
    return
end

func()
